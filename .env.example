# Anthropic API Key —— 用于调用 Claude 进行代码审查
# 获取地址: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Personal Access Token —— 用于拉取 PR diff、发布评论
# 获取地址: https://github.com/settings/tokens
# 所需权限: repo (读取私有仓库) 或 public_repo (仅公开仓库)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 使用的 Claude 模型（可选，默认 claude-opus-4-8）
# 备选: claude-sonnet-4-6（更快更省）、claude-haiku-4-5（最快）
ANTHROPIC_MODEL=claude-opus-4-8
