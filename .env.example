# ===== LLM 配置 =====
# 选择 LLM 厂商：deepseek（默认，成本低）或 claude
MODEL_PROVIDER=deepseek

# DeepSeek API Key（MODEL_PROVIDER=deepseek 时必填）
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key（可选，仅当 MODEL_PROVIDER=claude 时必填）
# 获取地址: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：覆盖默认模型
# DEEPSEEK_MODEL=deepseek-chat
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ===== GitHub 配置 =====
# GitHub Personal Access Token —— 用于拉取 PR diff、发布评论
# 获取地址: https://github.com/settings/tokens
# 所需权限: repo (读取私有仓库) 或 public_repo (仅公开仓库)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
